# ── Required ────────────────────────────────────────────────────────────────
# Get your FREE Groq API key at https://console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# ── Sandbox driver ──────────────────────────────────────────────────────────
# "docker"     -> hardened, isolated containers. Safe for public deploys.
#                 Requires Docker running + sandbox images built (see README).
# "subprocess" -> runs code as a local child process. Fast for dev on a trusted
#                 machine. DO NOT expose this on a public deployment.
SANDBOX=docker

# ── Optional tuning (defaults shown) ────────────────────────────────────────
# MODEL=openai/gpt-oss-120b
# MAX_TOKENS=8192
# MAX_ROUNDS=6
# EXEC_TIMEOUT=30        # seconds per sandbox run
# MEM_LIMIT_MB=512       # docker driver memory cap
# CPU_LIMIT=1.0          # docker driver CPU cap
# FLASK_DEBUG=0
# PORT=5000
